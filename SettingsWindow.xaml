<Window x:Class="SerpiumVPN.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Height="430" Width="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E24"
        FontFamily="Segoe UI"
        Icon="/serpium_vpn.ico">
    <Window.Resources>
        <Style x:Key="ToggleCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8E8EE"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent" MinHeight="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    x:Name="SwitchTrack"
                                    Width="46"
                                    Height="24"
                                    CornerRadius="12"
                                    Background="#252530"
                                    BorderBrush="#343447"
                                    BorderThickness="1">
                                <Ellipse x:Name="SwitchThumb"
                                         Width="18"
                                         Height="18"
                                         Fill="#A0A0AA"
                                         HorizontalAlignment="Left"
                                         Margin="3,0,0,0"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#008744"/>
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#00A957"/>
                                <Setter TargetName="SwitchThumb" Property="Fill" Value="White"/>
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888894"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#777783"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style x:Key="SettingsScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="#008744">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    Margin="0,0,10,0"/>
                            <ScrollBar Grid.Column="1"
                                       x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource SettingsScrollBarStyle}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#111116" CornerRadius="8" Margin="14" Padding="18" BorderBrush="#252535" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Настройки" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,18"/>

            <ScrollViewer Grid.Row="1" Style="{StaticResource SettingsScrollViewerStyle}">
                <StackPanel>
                    <Border Background="#16161F" BorderBrush="#252535" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Работа в фоне" Style="{StaticResource SectionTitleStyle}"/>
                            <CheckBox x:Name="CheckAutoSwitchStrategies"
                                      Content="Автосмена стратегии"
                                      Style="{StaticResource ToggleCheckBoxStyle}"
                                      IsChecked="False"
                                      Checked="SettingsToggle_Changed"
                                      Unchecked="SettingsToggle_Changed"/>
                            <TextBlock Text="Когда включено, программа сама меняет стратегию, если текущая просела по качеству связи." Style="{StaticResource HintTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#16161F" BorderBrush="#252535" BorderThickness="1" CornerRadius="8" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Обновления" Style="{StaticResource SectionTitleStyle}"/>

                            <CheckBox x:Name="CheckAutoUpdateFiles"
                                      Content="Автообновление файлов"
                                      Style="{StaticResource ToggleCheckBoxStyle}"
                                      IsChecked="True"
                                      Checked="SettingsToggle_Changed"
                                      Unchecked="SettingsToggle_Changed"/>

                            <CheckBox x:Name="CheckAutoUpdateProgram"
                                      Content="Автообновление программы"
                                      Style="{StaticResource ToggleCheckBoxStyle}"
                                      IsChecked="True"
                                      Margin="0,12,0,0"
                                      Checked="SettingsToggle_Changed"
                                      Unchecked="SettingsToggle_Changed"/>

                            <TextBlock Text="Автопроверка выполняется при запуске. Ручные проверки доступны ниже." Style="{StaticResource HintTextStyle}"/>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        x:Name="ButtonUpdateFiles"
                                        Content="Файлы"
                                        Height="38"
                                        Background="#252530"
                                        Foreground="#E8E8EE"
                                        BorderBrush="#343447"
                                        BorderThickness="1"
                                        Click="UpdateFiles_ClickAsync">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <Button Grid.Column="2"
                                        x:Name="ButtonCheckAppPatch"
                                        Content="Патч программы"
                                        Height="38"
                                        Background="#008744"
                                        Foreground="White"
                                        BorderBrush="#00A957"
                                        BorderThickness="1"
                                        Click="CheckAppPatch_ClickAsync">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
